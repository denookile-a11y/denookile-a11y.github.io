// DAILY ROTATION ENGINE
// Uses today's date as a deterministic seed
// so every visitor sees the same 5 quotes that day,
// and the display changes every calendar day.
// ══════════════════════════════════════════

function getDailySeed() {
  const now = new Date();
  return now.getFullYear() * 10000 + (now.getMonth() + 1) * 100 + now.getDate();
}

function seededShuffle(arr, seed) {
  const a = [...arr];
  let s = seed;
  for (let i = a.length - 1; i > 0; i--) {
    s = (s * 1664525 + 1013904223) & 0xffffffff;
    const j = Math.abs(s) % (i + 1);
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

let currentFilter = 'all';
let currentPage = 0;
const PAGE_SIZE = 6;

function getFilteredLibrary(filter) {
  if (filter === 'all') return WISDOM_LIBRARY;
  return WISDOM_LIBRARY.filter(w => w.c === filter);
}

function getDailySet(filter) {
  const lib = getFilteredLibrary(filter);
  const seed = getDailySeed();
  return seededShuffle(lib, seed);
}

function renderWisdom(filter = currentFilter, page = 0) {
  currentFilter = filter;
  currentPage = page;
  const grid = document.getElementById('wisdomGrid');
  const shuffled = getDailySet(filter);
  const slice = shuffled.slice(page * PAGE_SIZE, page * PAGE_SIZE + PAGE_SIZE);
  
  grid.style.opacity = '0';
  grid.style.transform = 'translateY(10px)';
  grid.style.transition = 'opacity 0.35s, transform 0.35s';

  setTimeout(() => {
    grid.innerHTML = '';
    slice.forEach((w, i) => {
      const card = document.createElement('div');
      card.className = 'wisdom-card';
      card.innerHTML = `
        <div class="wisdom-mark">"</div>
        <p class="wisdom-quote">${w.q}</p>
        <div class="wisdom-attribution">
          <span class="wisdom-line"></span>
          <span class="wisdom-author">${w.a}</span>
        </div>
        <div class="wisdom-icon" style="font-size:2.2rem;">${w.i}</div>
      `;
      grid.appendChild(card);
    });

    const total = Math.ceil(getDailySet(filter).length / PAGE_SIZE);
    updateWisdomNav(page, total);

    grid.style.opacity = '1';
    grid.style.transform = 'translateY(0)';
  }, 350);
}

function updateWisdomNav(page, total) {
  const nav = document.getElementById('wisdomNav');
  nav.innerHTML = `
    <button onclick="renderWisdom(currentFilter, ${page - 1})" ${page === 0 ? 'disabled style="opacity:0.3;cursor:not-allowed;"' : ''} style="background:transparent;border:1px solid rgba(212,175,119,0.35);color:var(--gold);padding:10px 20px;font-family:\'Cinzel\',serif;font-size:0.7rem;letter-spacing:0.15em;cursor:pointer;transition:all 0.3s;">← Prev</button>
    <span style="color:rgba(245,237,227,0.4);font-size:0.75rem;font-family:\'Lato\',sans-serif;letter-spacing:0.1em;">Page ${page + 1} of ${total} · ${WISDOM_LIBRARY.length} quotes in the library</span>
    <button onclick="renderWisdom(currentFilter, ${page + 1})" ${page >= total - 1 ? 'disabled style="opacity:0.3;cursor:not-allowed;"' : ''} style="background:transparent;border:1px solid rgba(212,175,119,0.35);color:var(--gold);padding:10px 20px;font-family:\'Cinzel\',serif;font-size:0.7rem;letter-spacing:0.15em;cursor:pointer;transition:all 0.3s;">Next →</button>
  `;
}

function shuffleWisdom() {
  // Jump to a random page within the current filter
  const total = Math.ceil(getDailySet(currentFilter).length / PAGE_SIZE);
  const randPage = Math.floor(Math.random() * total);
  renderWisdom(currentFilter, randPage);
}

